IDC_APPLICATION MENU
BEGIN
    POPUP "File(&F)"
    BEGIN
        MENUITEM "Exit(&X)",                IDM_EXIT
    END
    POPUP "Help(&H)"
    BEGIN
        MENUITEM "About(&A)...",           IDM_ABOUT
    END
END

/////////////////////////////////////////////////////////////////////////////
